# Refinex-DBFlow local environment template.
# 复制为本地 env 文件后再填值；不要把真实密码、Token、Token pepper 或 Nacos 密码提交到仓库。

# Spring Boot 启动入口。默认不启用 Nacos；启用 Nacos 时设为 nacos。
SPRING_PROFILES_ACTIVE="dbflow"
SPRING_CONFIG_ADDITIONAL_LOCATION="optional:file:./config/"
DBFLOW_SERVER_ADDRESS="127.0.0.1"
DBFLOW_SERVER_PORT=8080

# DBFlow metadata database：Flyway V1__create_metadata_schema.sql 只在这个库执行。
DBFLOW_METADATA_JDBC_URL="jdbc:mysql://127.0.0.1:3306/dbflow_metadata?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=true&allowPublicKeyRetrieval=false"
DBFLOW_METADATA_USERNAME="dbflow_meta"
DBFLOW_METADATA_PASSWORD="replace-with-secret"

# Nacos profile 连接参数；不启用 nacos profile 时不会使用。
DBFLOW_NACOS_SERVER_ADDR="127.0.0.1:8848"
DBFLOW_NACOS_NAMESPACE=
DBFLOW_NACOS_USERNAME="nacos_user"
DBFLOW_NACOS_PASSWORD="replace-with-secret"

# target database 默认账号与连接池参数。
DBFLOW_TARGET_USERNAME="dbflow_operator"
DBFLOW_TARGET_PASSWORD="replace-with-secret"
DBFLOW_TARGET_VALIDATE_ON_STARTUP=false
DBFLOW_TARGET_POOL_MAX_SIZE=10
DBFLOW_TARGET_POOL_MIN_IDLE=1
DBFLOW_TARGET_POOL_CONNECTION_TIMEOUT="30s"
DBFLOW_TARGET_POOL_IDLE_TIMEOUT="10m"
DBFLOW_TARGET_POOL_MAX_LIFETIME="30m"

# 示例 project/env。实际部署时按 Nacos 或外部 config/application-dbflow.yml 中的 dbflow.projects 对齐增删。
DBFLOW_DEMO_DEV_JDBC_URL="jdbc:mysql://127.0.0.1:3306/demo_dev?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=false"
DBFLOW_DEMO_DEV_USERNAME=
DBFLOW_DEMO_DEV_PASSWORD=
DBFLOW_DEMO_PROD_JDBC_URL="jdbc:mysql://10.0.0.20:3306/demo_prod?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=true&allowPublicKeyRetrieval=false"
DBFLOW_DEMO_PROD_USERNAME=
DBFLOW_DEMO_PROD_PASSWORD=

# 初始管理员只用于首次引导。推荐使用 DBFLOW_ADMIN_INITIAL_PASSWORD_HASH，生成方式见 docs/deployment/README.md。
DBFLOW_ADMIN_INITIAL_USER_ENABLED=false
DBFLOW_ADMIN_INITIAL_USERNAME="admin"
DBFLOW_ADMIN_INITIAL_DISPLAY_NAME="DBFlow Administrator"
DBFLOW_ADMIN_INITIAL_PASSWORD=
DBFLOW_ADMIN_INITIAL_PASSWORD_HASH=

# MCP Token 与 /mcp endpoint 安全参数。
DBFLOW_MCP_TOKEN_PEPPER="replace-with-secret"
DBFLOW_MCP_TRUSTED_ORIGIN="http://127.0.0.1:8080"
DBFLOW_MCP_MAX_REQUEST_BYTES=1048576
DBFLOW_MCP_RATE_LIMIT_MAX_REQUESTS=120
DBFLOW_MCP_RATE_LIMIT_WINDOW="1m"

# MCP 客户端本地 smoke test 可使用的占位变量；服务端不会读取这个变量。
DBFLOW_MCP_TOKEN="dbflow_xxx_fake_replace_me"
